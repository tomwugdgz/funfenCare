# Application Settings
APP_NAME=funfenCare
APP_VERSION=2.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/funfencare

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SMS Service (for login verification)
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SIGN=funfenCare

# MQTT (IoT Gateway)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=funfencare
MQTT_PASSWORD=funfencare

# InfluxDB (Time-series data for CSI)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=funfencare
INFLUXDB_BUCKET=csi_data

# WeChat Mini Program
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
