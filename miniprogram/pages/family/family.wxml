<!--pages/family/family.wxml-->
<view class="container">
  <view class="header-card">
    <text class="title">亲情圈管理</text>
    <text class="subtitle">添加家人，共同关注老人安全</text>
  </view>

  <!-- 添加家人表单 -->
  <view class="card add-form">
    <text class="card-title">添加家人</text>
    <view class="form-group">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入家人手机号" bindinput="onPhoneInput" value="{{phone}}" />
    </view>
    <view class="form-group">
      <text class="label">关系</text>
      <picker bindchange="onRelationChange" value="{{relationIndex}}" range="{{relations}}">
        <view class="picker-value">{{relations[relationIndex]}}</view>
      </picker>
    </view>
    <button class="btn btn-primary" bindtap="bindFamily">确认添加</button>
  </view>

  <!-- 已添加的家人 -->
  <view class="card">
    <text class="card-title">家人列表</text>
    <view wx:for="{{familyList}}" wx:key="id" class="family-item">
      <view class="family-avatar">
        <text class="avatar-icon">{{item.role === 'elder' ? '👴' : '👨‍👩‍👧'}}</text>
      </view>
      <view class="family-info">
        <text class="family-name">{{item.name || '未设置'}}</text>
        <text class="family-phone">{{item.phone}}</text>
      </view>
      <view class="family-badge {{item.role === 'elder' ? 'elder' : 'guardian'}}">
        <text class="badge-text">{{item.role === 'elder' ? '老人' : '监护人'}}</text>
      </view>
    </view>
    <view wx:if="{{familyList.length === 0}}" class="empty-text">
      还没有添加家人
    </view>
  </view>
</view>
