/* pages/family/family.wxss */
.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 32rpx;
}

.header-card {
  background-color: #2196F3;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 8rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.label {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.input {
  background-color: #F8F9FA;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 36rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-value {
  background-color: #F8F9FA;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 36rpx;
  color: #333;
}

/* 家人列表 */
.family-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.family-item:last-child {
  border-bottom: none;
}

.family-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #E3F2FD;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-icon {
  font-size: 48rpx;
}

.family-info {
  flex: 1;
}

.family-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.family-phone {
  font-size: 28rpx;
  color: #666;
  margin-top: 4rpx;
  display: block;
}

.family-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.family-badge.elder {
  background-color: #E3F2FD;
}

.family-badge.guardian {
  background-color: #E8F5E9;
}

.badge-text {
  font-size: 24rpx;
  font-weight: 600;
}

.empty-text {
  text-align: center;
  font-size: 32rpx;
  color: #999;
  padding: 60rpx 0;
}
