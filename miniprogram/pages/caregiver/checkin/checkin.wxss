/* pages/caregiver/checkin/checkin.wxss */
.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 32rpx;
}

.header-card {
  background: linear-gradient(135deg, #FF5722 0%, #E64A19 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title { font-size: 48rpx; font-weight: bold; color: #ffffff; display: block; }
.subtitle { font-size: 32rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.info-label { font-size: 32rpx; color: #666; }
.info-value { font-size: 32rpx; font-weight: 600; color: #333; }

.location-box {
  background: #FFF3CD;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.location-box.success { background: #D4EDDA; }
.location-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.location-text { font-size: 36rpx; font-weight: 600; display: block; margin-bottom: 4rpx; }
.location-distance { font-size: 28rpx; color: #666; }

.check-location-btn {
  margin-top: 12rpx;
}

.photo-area {
  background: #F8F9FA;
  border: 4rpx dashed #E0E0E0;
  border-radius: 24rpx;
  padding: 60rpx 0;
  text-align: center;
}

.photo-icon { font-size: 80rpx; display: block; margin-bottom: 12rpx; }
.photo-text { font-size: 32rpx; color: #999; }

.photo-preview {
  margin-top: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-preview image {
  width: 100%;
  border-radius: 16rpx;
}

.label {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.radio-group { margin-bottom: 24rpx; }

.radio-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 32rpx;
}

.textarea {
  background: #F8F9FA;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.btn-primary { background: #FF5722; color: #ffffff; }
.btn-outline { background: #ffffff; color: #FF5722; border: 4rpx solid #FF5722; }
.submit-btn { margin-top: 24rpx; }
.submit-btn.disabled { background: #ccc; }
