/* pages/caregiver/dashboard/caregiver-dashboard.wxss */
.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 32rpx;
}

.header-card {
  background: linear-gradient(135deg, #FF5722 0%, #E64A19 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF5722;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 4rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-type {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.distance-badge {
  font-size: 28rpx;
  color: #2196F3;
}

.order-info {
  margin-bottom: 12rpx;
}

.info-item {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.order-notes {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.accept-btn {
  margin-top: 0;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #999;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.btn-primary {
  background-color: #FF5722;
  color: #ffffff;
}
