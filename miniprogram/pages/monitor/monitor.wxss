/* pages/monitor/monitor.wxss */
.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 32rpx;
}

.header-card {
  background-color: #2196F3;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.elder-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.monitor-date {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

/* 活动曲线图 */
.chart-container {
  display: flex;
  align-items: flex-end;
  height: 240rpx;
  gap: 8rpx;
  padding-top: 20rpx;
}

.chart-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-bar {
  width: 100%;
  border-radius: 4rpx;
  min-height: 8rpx;
}

.chart-bar.high { background-color: #4CAF50; }
.chart-bar.medium { background-color: #FF9800; }
.chart-bar.low { background-color: #E0E0E0; }

.chart-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 状态网格 */
.status-grid {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.status-value {
  font-size: 44rpx;
  font-weight: bold;
}

.status-value.good { color: #4CAF50; }
.status-value.danger { color: #FF4444; }
.status-value.online { color: #2196F3; }

/* AI分析 */
.insights {
  background-color: #FFF3CD;
}

.insight-item {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
