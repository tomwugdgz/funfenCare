<view class="login-container">
  <!-- Logo -->
  <view class="logo-section">
    <text class="logo-icon">☀️</text>
    <text class="title">funfenCare</text>
    <text class="subtitle">让远方的家人安心</text>
  </view>

  <!-- Login Form -->
  <view class="form-section">
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" 
             type="number" 
             maxlength="11" 
             placeholder="请输入手机号"
             value="{{phone}}"
             bindinput="onPhoneInput" />
    </view>

    <view class="input-group">
      <text class="label">验证码</text>
      <view class="code-row">
        <input class="input code-input" 
               type="number" 
               maxlength="6" 
               placeholder="请输入验证码"
               value="{{code}}"
               bindinput="onCodeInput" />
        <button class="send-btn {{countdown > 0 ? 'disabled' : ''}}"
                bindtap="sendCode"
                disabled="{{countdown > 0}}">
          {{countdown > 0 ? countdown + '秒' : '获取验证码'}}
        </button>
      </view>
    </view>

    <!-- 角色选择 -->
    <view class="role-section">
      <text class="label">我是</text>
      <view class="role-options">
        <view class="role-item {{role === 'guardian' ? 'active' : ''}}"
              bindtap="onRoleChange" 
              data-role="guardian">
          <text class="role-icon">👨‍👩‍👧</text>
          <text class="role-text">我是子女</text>
        </view>
        <view class="role-item {{role === 'elder' ? 'active' : ''}}"
              bindtap="onRoleChange" 
              data-role="elder">
          <text class="role-icon">👴</text>
          <text class="role-text">我是老人</text>
        </view>
        <view class="role-item {{role === 'caregiver' ? 'active' : ''}}"
              bindtap="onRoleChange" 
              data-role="caregiver">
          <text class="role-icon">🚪</text>
          <text class="role-text">我是服务人员</text>
        </view>
      </view>
    </view>

    <button class="btn btn-primary login-btn" 
            bindtap="handleLogin"
            disabled="{{loading}}">
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <view class="agreement">
      <text class="agree-text">登录即表示同意</text>
      <navigator class="link" url="/pages/agreement/user">《用户协议》</navigator>
      <text class="agree-text">和</text>
      <navigator class="link" url="/pages/agreement/privacy">《隐私政策》</navigator>
    </view>
  </view>
</view>
