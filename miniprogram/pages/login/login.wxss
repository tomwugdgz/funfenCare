/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F7FA 40%);
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

.logo-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 80rpx;
  font-weight: bold;
  color: #2196F3;
}

.subtitle {
  font-size: 40rpx;
  color: #666;
  margin-top: 16rpx;
}

.form-section {
  flex: 1;
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.input {
  background-color: #ffffff;
  border: 2rpx solid #E0E0E0;
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 40rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 24rpx;
}

.code-input {
  flex: 1;
}

.send-btn {
  background-color: #2196F3;
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  min-width: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn.disabled {
  background-color: #999;
}

.role-section {
  margin-bottom: 48rpx;
}

.role-options {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.role-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background-color: #ffffff;
  border: 4rpx solid #E0E0E0;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.role-item.active {
  border-color: #2196F3;
  background-color: #E3F2FD;
}

.role-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.role-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.login-btn {
  margin-top: 48rpx;
}

.agreement {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 40rpx;
  padding-bottom: 60rpx;
}

.agree-text {
  font-size: 28rpx;
  color: #999;
}

.link {
  font-size: 28rpx;
  color: #2196F3;
  margin: 0 8rpx;
}
