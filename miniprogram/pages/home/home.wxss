/* pages/home/home.wxss */
.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #2196F3;
  padding: 40rpx 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.avatar {
  font-size: 64rpx;
}

.section {
  padding: 32rpx;
}

.section-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

/* 老人卡片 */
.elder-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.elder-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.elder-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background-color: #E3F2FD;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.elder-avatar-icon {
  font-size: 72rpx;
}

.elder-info {
  flex: 1;
}

.elder-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}

.status-badge.good { background-color: #4CAF50; }
.status-badge.warning { background-color: #FF9800; }
.status-badge.danger { background-color: #FF4444; }

.status-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.activity-row {
  display: flex;
  justify-content: space-around;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.activity-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.activity-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #2196F3;
}

.activity-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.insights-box {
  background-color: #FFF3CD;
  border-radius: 16rpx;
  padding: 24rpx;
}

.insights-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF9800;
  display: block;
  margin-bottom: 12rpx;
}

.insight-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 40rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.add-btn {
  padding: 24rpx 64rpx;
  font-size: 40rpx;
}

/* 服务网格 */
.services-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.service-item {
  flex: 1;
  min-width: 45%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.service-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.service-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}
